      "boundElements": [],
      "updated": 1774926445129,
      "link": null,
      "locked": false,
      "text": "Security:\n- Lambda(s) assigned least-privilege\nIAM role scoped to just this table\nand GSI\n- AWS managed encryption\n- CloudWatch logs for Lambda\nexecution + error monitoring",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "Y3HaqzIK2zlaFhsC7Odt2",
      "originalText": "Security:\n- Lambda(s) assigned least-privilege IAM role scoped to just this table and GSI\n- AWS managed encryption\n- CloudWatch logs for Lambda execution + error monitoring",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "wJgW0UyygL1Koeev05YYJ",
