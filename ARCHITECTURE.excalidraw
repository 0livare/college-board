      "updated": 1774760332034,
      "link": null,
      "locked": false,
      "text": "In production deploying a\nseparate lambda for each\nhandler would allow\nindividual scaling. \n\nI used a single lambda to\nreduce complexity for this\nexercise.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "wJgW0UyygL1Koeev05YYJ",
      "originalText": "In production deploying a separate lambda for each handler would allow  individual scaling. \n\nI used a single lambda to reduce complexity for this exercise.",
      "autoResize": true,
      "lineHeight": 1.25
    },
