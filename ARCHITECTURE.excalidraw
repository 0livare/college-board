      "updated": 1774900900430,
      "link": null,
      "locked": false,
      "text": "- one Dynamo table because all queries\nare item driven\n\n- current item:\n    - PK: ITEM#{id}\n    - SK: CURRENT\n- version snapshot:\n    - PK: ITEM#{id}\n    - SK: VERSION#{versionId}\n- audit event:\n    - PK: ITEM#{id}\n    - SK: AUDIT#{auditId}",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "b5w41bRNgYq5NWWASCEob",
      "originalText": "- one Dynamo table because all queries are item driven\n\n- current item:\n    - PK: ITEM#{id}\n    - SK: CURRENT\n- version snapshot:\n    - PK: ITEM#{id}\n    - SK: VERSION#{versionId}\n- audit event:\n    - PK: ITEM#{id}\n    - SK: AUDIT#{auditId}",
      "autoResize": true,
      "lineHeight": 1.25
    },
