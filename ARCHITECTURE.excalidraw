      "text": "Security:\n- Lambda(s) assigned least-privilege\nIAM role scoped to just this table\n- CloudWatch logs",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "Y3HaqzIK2zlaFhsC7Odt2",
      "originalText": "Security:\n- Lambda(s) assigned least-privilege IAM role scoped to just this table\n- CloudWatch logs",
      "autoResize": true,
      "lineHeight": 1.25
    },
