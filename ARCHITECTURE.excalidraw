      "boundElements": [],
      "updated": 1774900903328,
      "link": null,
      "locked": false,
      "text": "Project current items into a GSI\n\n- PK: ITEM\n- SK:{id}\n\nThis adds support for the paginated\nlist items query because the\nExamItemIds that I'm using are\nlexicographically sortable. Created date\ncould also work for the SK.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "FWd6xbR4norSfW3Vn5_xP",
      "originalText": "Project current items into a GSI\n\n- PK: ITEM\n- SK:{id}\n\nThis adds support for the paginated list items query because the ExamItemIds that I'm using are lexicographically sortable. Created date could also work for the SK.",
      "autoResize": true,
      "lineHeight": 1.25
    },
