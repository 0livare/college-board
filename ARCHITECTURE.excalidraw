    {
      "id": "OD_h94bxNwg2ncrFXpn43",
      "type": "text",
      "x": 1630.54296875,
      "y": 89.02343749999997,
      "width": 307.47198486328125,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "cross-hatch",
      "strokeWidth": 2,
      "strokeStyle": "solid",
