      "link": null,
      "locked": false,
      "text": "- Get/create/update item → query PK=ITEM#{id}, SK=CURRENT\n- Create version → write VERSION#{versionId}\n- Get audit → query PK=ITEM#{id}, SK begins with AUDIT#\n- List items → query GSI PK=ITEM",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "1N3c3OCjobQF3BKgistHH",
      "originalText": "- Get/create/update item → query PK=ITEM#{id}, SK=CURRENT\n- Create version → write VERSION#{versionId}\n- Get audit → query PK=ITEM#{id}, SK begins with AUDIT#\n- List items → query GSI PK=ITEM",
      "autoResize": true,
      "lineHeight": 1.25
    },
